#include <iostream>
#include <string>
using namespace ::std;
string storstring(string text)
{


    for (int a = 0; a < text.size(); a++)  //حلقه لوب
    {

        for (int i = 0; i < text.size(); i++)
        {
            text[i] = toupper(text[i]);  //تحويل جميع الحروف الى كبير
            for (int j = i + 1; j < text.size(); j++)
            {

                if (text[i] > text[j])  //شرط ترتيب الحروف
                {
                    char y = text[i];
                    text[i] = text[j];
                    text[j] = y;
                    

                }
            }

        }
    }



    return text;
}
int main()  //تطبيق عملي
{
    string x;
    getline(cin, x);

    cout << storstring(x) << endl;

    return 0;

}
